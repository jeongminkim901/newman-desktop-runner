{
  "name": "newman-desktop-runner",
  "version": "0.1.0",
  "description": "Desktop UI for running Postman collections with Newman",
  "main": "main.js",
  "author": "jeongminkim901",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "lint": "echo \"(no lint yet)\"",
    "test:unit": "jest --runInBand",
    "test:e2e": "node tests/e2e/run.js",
    "test": "npm run test:unit && npm run test:e2e",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "js-yaml": "^4.1.0",
    "newman": "^6.2.1",
    "openapi-to-postmanv2": "^5.0.0",
    "playwright": "^1.49.0"
  },
  "build": {
    "appId": "com.jeongmin.newmanrunner",
    "productName": "Newman Desktop Runner",
    "icon": "build/icon.png",
    "publish": [
      {
        "provider": "generic",
        "url": "https://github.com/jeongminkim901/newman-desktop-runner/releases/latest/download/"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "files": [
      "**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
